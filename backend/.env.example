# ---------------------------------------------------------------------------
# Example environment file. Copy to `.env` and adjust for LOCAL host development:
#
#     cp .env.example .env
#
# config.py loads this via python-dotenv. The REAL `.env` is gitignored — never
# commit it. When running via docker-compose you don't need a .env at all;
# compose sets these variables for the container.
# ---------------------------------------------------------------------------

# SQLAlchemy database URL (note the +psycopg2 driver).
# Format: postgresql+psycopg2://user:password@host:port/dbname
DATABASE_URL=

# Comma-separated browser origins allowed to call the API (the React dev server).
# e.g. http://localhost:5173,http://localhost:3000
CORS_ORIGINS=

# Paths to the source data files the loader reads.
# e.g. ../data/listings.csv,../data/helsinki_areas.geojson
LISTINGS_CSV=
AREAS_GEOJSON=

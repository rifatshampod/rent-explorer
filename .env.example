# Copy this file to `.env` and adjust as needed:  cp .env.example .env
#
# Every variable below ALSO has a built-in fallback in docker-compose.yml
# (the `${VAR:-default}` syntax), so the stack runs even with no `.env` at all.
# These values are the local demo defaults — safe for local dev, NOT for prod.

# --- Database credentials (single source of truth: the API's DATABASE_URL is
#     assembled from these same three values inside docker-compose.yml) --------
POSTGRES_USER=rentdbuser
POSTGRES_PASSWORD=rentStrongPassword
POSTGRES_DB=rentexplorer

# --- Host port mappings ----------------------------------------------------
DB_PORT=5432
API_PORT=8000
WEB_PORT=5173

# --- Frontend / API wiring -------------------------------------------------
# Base URL the browser uses to reach the API (as seen from the host machine).
VITE_API_URL=http://localhost:8000
# Browser origins the API accepts (comma-separated).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
